{
  "name": "adaptive-questionnaire-system",
  "version": "1.0.0",
  "description": "Adaptive Client Questionnaire System - Backend API",
  "private": true,
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "start:dev": "turbo run start:dev --filter=api",
    "start:prod": "turbo run start:prod --filter=api",
    "test": "turbo run test",
    "test:api": "cd apps/api && npm test",
    "test:api:integration": "cd apps/api && npm run test:integration",
    "test:api:validation": "cd apps/api && npm test -- --testPathPattern=validation",
    "test:api:common": "cd apps/api && npm test -- --testPathPattern=common",
    "test:cli": "cd apps/cli && npm test",
    "test:watch": "turbo run test:watch",
    "test:cov": "turbo run test:cov",
    "test:regression": "npx jest --config=test/regression/jest.config.js",
    "test:performance": "npx jest --config=test/performance/jest.config.js",
    "test:e2e": "playwright test",
    "test:e2e:local": "PLAYWRIGHT_NO_WEBSERVER=1 playwright test --project=chromium",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report e2e/reports",
    "test:e2e:install": "playwright install",
    "test:load": "node test/performance/autocannon-load.js",
    "test:load:light": "DURATION=10 CONNECTIONS=50 node test/performance/autocannon-load.js",
    "test:lighthouse": "lhci autorun",
    "test:perf": "npm run test:load && npm run test:lighthouse",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "cloud:login": "az acr login --name acrquestionnaireprod",
    "cloud:build": "docker build -t acrquestionnaireprod.azurecr.io/quiz-api:latest -f docker/api/Dockerfile .",
    "cloud:push": "docker push acrquestionnaireprod.azurecr.io/quiz-api:latest",
    "cloud:deploy": "az containerapp update --name ca-questionnaire-api-prod --resource-group rg-questionnaire-prod --image acrquestionnaireprod.azurecr.io/quiz-api:latest",
    "cloud:all": "npm run cloud:login && npm run cloud:build && npm run cloud:push && npm run cloud:deploy",
    "validate:skills": "node scripts/validate-skills.js",
    "prepare": "echo husky disabled for OneDrive path compatibility"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.39.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^10.1.0",
    "@playwright/test": "^1.58.0",
    "@swc/cli": "^0.1.63",
    "@swc/core": "^1.15.11",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^7.0.0",
    "@types/jest": "^29.5.14",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.16.0",
    "autocannon": "^8.0.0",
    "axe-core": "^4.11.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^5.1.0",
    "exit-x": "^0.2.2",
    "globals": "^17.3.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-axe": "^10.0.0",
    "jest-util": "^30.2.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.2.0",
    "pa11y": "^9.0.1",
    "pkg-up": "^4.0.0",
    "prettier": "^3.2.0",
    "prisma": "^5.8.0",
    "stripe": "^20.2.0",
    "@nestjs/testing": "^10.3.0",
    "@vitest/utils": "^4.0.18",
    "ts-jest": "^29.4.6",
    "tsc-alias": "^1.8.16",
    "vitest": "^4.0.18",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^1.11.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.36.0",
    "webpack": "^5.105.3"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@azure/storage-blob": "^12.30.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/context-async-hooks": "^2.5.1",
    "archiver": "^4.0.2",
    "docx": "^9.5.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  "overrides": {
    "basic-ftp": "5.2.0",
    "lodash": "4.17.21",
    "minimatch": "10.2.4",
    "qs": "6.14.2",
    "tmp": "0.2.4",
    "fast-xml-parser": "5.3.8",
    "minimist": "1.2.8",
    "xmldom": "0.6.0",
    "cross-spawn": "7.0.6",
    "ws": "8.18.2",
    "js-yaml": "4.1.1",
    "serialize-javascript": "7.0.4",
    "multer": "2.1.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.57.0"
  }
}