# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ============================================
# AZURE CONTAINER REGISTRY (Docker Cloud)
# ============================================
# Primary container registry - DO NOT use Docker Desktop
ACR_LOGIN_SERVER=acrquestionnaireprod.azurecr.io
ACR_USERNAME=acrquestionnaireprod
ACR_PASSWORD=your-acr-password-from-azure-portal
# Image names
ACR_API_IMAGE=acrquestionnaireprod.azurecr.io/quiz-api:latest
ACR_WEB_IMAGE=acrquestionnaireprod.azurecr.io/quiz-web:latest

# ============================================
# AZURE PRODUCTION ENDPOINTS
# ============================================
AZURE_API_URL=https://ca-questionnaire-api-prod.wittyriver-206156ea.australiasoutheast.azurecontainerapps.io
AZURE_WEB_URL=https://ca-questionnaire-web-prod.wittyriver-206156ea.australiasoutheast.azurecontainerapps.io

# Database (Azure PostgreSQL for production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/questionnaire?schema=public
# Database Connection Pool (optional - defaults: connection_limit=20, pool_timeout=10)
DATABASE_CONNECTION_LIMIT=20
DATABASE_POOL_TIMEOUT=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
THROTTLE_LOGIN_LIMIT=5

# Logging
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:3001

# Frontend URL (used for email links, redirects)
FRONTEND_URL=http://localhost:3001

# Azure Blob Storage (for Document Generator)
# Option 1: Connection String (recommended for local dev)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1
# Option 2: For Azure (use Managed Identity or real connection string)
# AZURE_STORAGE_ACCOUNT_NAME=youraccountname
AZURE_STORAGE_CONTAINER_NAME=documents

# Claude AI (Anthropic) — required for idea analysis & document generation
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# Email (Brevo / SendGrid)
BREVO_API_KEY=
EMAIL_FROM=noreply@quiz2biz.com
EMAIL_FROM_NAME=Quiz2Biz

# Stripe Payments (optional — required for billing features)
STRIPE_SECRET_KEY=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# Auth Token Expiry (optional)
# VERIFICATION_TOKEN_EXPIRY=24h
# PASSWORD_RESET_TOKEN_EXPIRY=1h

# Feature Flags
ENABLE_LEGACY_MODULES=false
# LAUNCHDARKLY_SDK_KEY=
# LAUNCHDARKLY_OFFLINE=false

# Sentry Error Tracking (optional)
# SENTRY_DSN=
# SENTRY_RELEASE=quiz2biz-api@1.0.0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1
# SENTRY_DEBUG=false

# Azure Application Insights (optional — production observability)
# APPLICATIONINSIGHTS_CONNECTION_STRING=
# AZURE_CLOUD_ROLE=quiz-to-build-api

# Alerting & Notifications (optional — production ops)
# SLACK_WEBHOOK_URL=
# TEAMS_WEBHOOK_URL=
# PAGERDUTY_SERVICE_KEY=
# ALERT_EMAIL_RECIPIENTS=

# Azure Infrastructure (optional — disaster recovery & chaos engineering)
# AZURE_KEY_VAULT_URL=
# DATABASE_URL_SECONDARY=
