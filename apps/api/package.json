{
  "name": "api",
  "version": "1.0.0",
  "description": "Adaptive Questionnaire System - NestJS API",
  "private": true,
  "scripts": {
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "npx jest --detectOpenHandles --forceExit",
    "test:watch": "npx jest --watch --detectOpenHandles",
    "test:cov": "npx jest --coverage --detectOpenHandles --forceExit",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "npx jest --config ./test/jest-e2e.json",
    "test:integration": "npx jest --config ./test/jest-integration.json",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.17.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "5.22.0",
    "@sentry/nestjs": "^10.40.0",
    "@sentry/node": "10.40.0",
    "@swc/cli": "0.1.63",
    "@types/cookie-parser": "^1.4.10",
    "applicationinsights": "^3.13.0",
    "archiver": "4.0.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "docx": "^9.5.1",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "nestjs-pino": "^4.6.0",
    "otplib": "^13.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "stripe": "^20.3.1",
    "typescript-eslint": "^8.0.0",
    "uuid": "^9.0.1",
    "webpack": "^5.105.3"
  },
  "devDependencies": {
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.8",
    "@types/passport-jwt": "^4.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "prisma": "5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.2.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.(spec|test)\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "diagnostics": {
            "warnOnly": true
          },
          "isolatedModules": true
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.module.ts",
      "!**/main.ts",
      "!**/*.spec.ts",
      "!**/*.test.ts",
      "!**/index.ts"
    ],
    "coverageDirectory": "../coverage",
    "coverageProvider": "v8",
    "coverageReporters": [
      "text",
      "lcov",
      "html",
      "json-summary"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "cacheDirectory": "<rootDir>/../.jest-cache",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@libs/database(.*)$": "<rootDir>/../../../libs/database/src$1",
      "^@libs/redis(.*)$": "<rootDir>/../../../libs/redis/src$1",
      "^@libs/shared(.*)$": "<rootDir>/../../../libs/shared/src$1",
      "^archiver$": "<rootDir>/../../../node_modules/archiver"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(readdir-glob|minimatch|brace-expansion|balanced-match)/)"
    ]
  }
}