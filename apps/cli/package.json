{
    "name": "@quiz2biz/cli",
    "version": "1.0.0",
    "description": "Quiz2Biz Readiness Assessment CLI Tool",
    "main": "dist/index.js",
    "bin": {
        "quiz2biz": "./dist/index.js",
        "q2b": "./dist/index.js"
    },
    "scripts": {
        "build": "npx tsc",
        "start": "node dist/index.js",
        "dev": "ts-node src/index.ts",
        "lint": "eslint src --ext .ts",
        "test": "npx jest",
        "test:watch": "npx jest --watch",
        "test:cov": "npx jest --coverage --testPathPattern=config.test.ts",
        "test:all": "npx jest",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "quiz2biz",
        "readiness",
        "assessment",
        "cli"
    ],
    "author": "Quiz2Biz Team",
    "license": "MIT",
    "dependencies": {
        "@nestjs/cli": "^11.0.16",
        "@nestjs/core": "^10.3.0",
        "@nestjs/schedule": "^4.1.0",
        "@nestjs/schematics": "^10.1.0",
        "@nestjs/swagger": "^7.4.0",
        "@nestjs/testing": "^10.3.0",
        "@sentry/nestjs": "^8.19.0",
        "@sentry/node": "9.20.0",
        "@swc/cli": "0.1.63",
        "archiver": "4.0.2",
        "axios": "^1.13.5",
        "chalk": "^4.1.2",
        "commander": "^11.1.0",
        "conf": "^10.2.0",
        "inquirer": "^8.2.6",
        "ora": "^5.4.1",
        "table": "^6.8.1",
        "webpack": "^5.105.3"
    },
    "devDependencies": {
        "@types/inquirer": "^9.0.7",
        "@types/jest": "^30.0.0",
        "@types/node": "^20.10.0",
        "eslint": "^9.0.0",
        "eslint-plugin-jsx-a11y": "^6.10.0",
        "jest": "^29.0.0",
        "ts-jest": "^29.0.0",
        "typescript": "^5.3.0",
        "typescript-eslint": "^8.0.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "files": [
        "dist",
        "README.md"
    ]
}